#!/bin/bash
# lamboot-signing-keys — Secure Boot key lifecycle helper
#
# Dual-mode per founder decision Q1=Scope3: covers both release-engineering
# (lamboot-dev/KEY-GENERATION.md procedures) and user-facing Secure Boot key
# management (mokutil/OVMF vars/sbsign wrappers).
#
# RSA-2048 enforcement on db / MOK-bound keys per Debian bug #1013320.
# RSA-4096 allowed for PK/KEK (firmware-level, not shim-path).
#
# Governed by docs/SPEC-LAMBOOT-SIGNING-KEYS.md.
# Part of the lamboot-tools suite (SPEC-LAMBOOT-TOOLKIT-V1.md §3.1).

# shellcheck source=../lib/lamboot-toolkit-lib.sh
source "${LAMBOOT_LIB_DIR:-/usr/lib/lamboot-tools}/lamboot-toolkit-lib.sh"
# shellcheck source=../lib/lamboot-toolkit-help.sh
source "${LAMBOOT_LIB_DIR:-/usr/lib/lamboot-tools}/lamboot-toolkit-help.sh"

LAMBOOT_TOOL_NAME="lamboot-signing-keys"
LAMBOOT_TOOL_VERSION="0.3.0"

readonly DOC_BASE="https://lamboot.dev/tools/findings"

OPT_SUBCOMMAND=""
OPT_MODE="auto"
OPT_TYPE="db"
OPT_SIZE=""
OPT_CN=""
OPT_DAYS=""
OPT_OUTPUT=""
OPT_OUTPUT_DIR=""
OPT_INPUT=""
OPT_KEY=""
OPT_CERT=""
OPT_FORCE_4096=0
OPT_PASSPHRASE_SRC="prompt"
OPT_NEW_CN=""
OPT_SBAT=""              # explicit SBAT CSV line (e.g. "lamboot,1,LamCo,lamboot,0.8.4,...")
OPT_SBAT_FILE=""         # path to SBAT CSV file; overrides OPT_SBAT if both given
OPT_NO_SBAT=0            # skip SBAT injection (not recommended; for debugging)
OPT_OLD_KEY=""           # rotate: existing key being retired
OPT_OLD_CERT=""          # rotate: existing cert being retired
OPT_PARENT_KEY=""        # rotate: parent key used to cross-sign new cert
OPT_PARENT_CERT=""       # rotate: parent cert used to cross-sign new cert

# ── Help registry ────────────────────────────────────────────────────────

_register_subcommands() {
    register_subcommand \
        --name "generate" \
        --category "Keys" \
        --summary "Generate a signing keypair + cert" \
        --syntax "lamboot-signing-keys generate [--type db|kek|pk] [--size N] [--cn NAME] [--days N] [--output PREFIX]" \
        --arg "--type db|kek|pk:Key role (default: db)" \
        --arg "--size N:RSA key size (default: 2048 for db, 4096 for pk/kek)" \
        --arg "--cn NAME:Subject CommonName" \
        --arg "--days N:Validity (default: 1095 for db, 3650 for pk/kek)" \
        --arg "--output PREFIX:Output prefix; produces PREFIX.key + PREFIX.crt + PREFIX.der (default: ./<type>)" \
        --arg "--force-4096:Override RSA-2048 constraint for db (dangerous; shim freezes per Debian #1013320)" \
        --example "lamboot-signing-keys generate --type db --cn 'My db Key 2026'" \
        --example "lamboot-signing-keys generate --type pk --output /tmp/mypk" \
        --notes "RSA-2048 is enforced for db keys because Debian bug #1013320 causes shim to freeze verifying RSA-4096 MOK certs. RSA-4096 is safe for PK/KEK. Private key is 0600; cert is 0644." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "inspect, mok-enroll, status" \
        --doc-url "https://lamboot.dev/tools/signing-keys/generate" \
        --maturity "experimental"

    register_subcommand \
        --name "rotate" \
        --category "Keys" \
        --summary "Rotate a db/kek/pk keypair, cross-signing with the parent key" \
        --syntax "lamboot-signing-keys rotate TYPE --old-key K --old-cert C [--new-cn NAME] [--parent-key K --parent-cert C] [--output-dir DIR]" \
        --arg "TYPE:db | kek | pk" \
        --arg "--old-key PATH:Existing private key being rotated" \
        --arg "--old-cert PATH:Existing cert being rotated" \
        --arg "--new-cn NAME:CN for the new cert (default: inherits old CN with '-rotated-YYYYMMDD' suffix)" \
        --arg "--parent-key PATH:Parent private key for cross-sign (KEK for db rotation, PK for KEK rotation). Optional; if absent, rotation produces a self-signed new cert and emits a warning." \
        --arg "--parent-cert PATH:Parent cert for cross-sign (must match --parent-key)" \
        --arg "--output-dir DIR:Rotation artifacts directory (default: ./rotation-TYPE-YYYYMMDD-HHMMSS)" \
        --example "sudo lamboot-signing-keys rotate db --old-key keys/db.key --old-cert keys/db.crt --parent-key keys/kek.key --parent-cert keys/kek.crt" \
        --example "sudo lamboot-signing-keys rotate kek --old-key keys/kek.key --old-cert keys/kek.crt --parent-key keys/pk.key --parent-cert keys/pk.crt" \
        --example "sudo lamboot-signing-keys rotate pk --old-key keys/pk.key --old-cert keys/pk.crt" \
        --notes "Generates a new keypair with the same RSA size + validity defaults as generate, then cross-signs the new cert with the parent key (db←KEK, KEK←PK, PK←self). Produces a timestamped rotation directory containing old + new keypairs, a transition manifest, and re-enrollment instructions. Both old and new keys remain valid during the transition window; stragglers can be re-signed with either old or new db until distribution completes. See KEY-GENERATION.md §6.1." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "generate, generate-hierarchy, mok-enroll" \
        --doc-url "https://lamboot.dev/tools/signing-keys/rotate" \
        --maturity "experimental"

    register_subcommand \
        --name "inspect" \
        --category "Keys" \
        --summary "Display cert subject, algorithm, key size, validity" \
        --syntax "lamboot-signing-keys inspect KEYFILE_OR_CERT [--json]" \
        --arg "KEYFILE_OR_CERT:Path to .key, .crt, .der, or .pem" \
        --example "lamboot-signing-keys inspect /etc/keys/db.crt" \
        --example "lamboot-signing-keys inspect myKey.der --json" \
        --notes "Parses via openssl. Warns on RSA-4096 leaf certs, expiring certs (<90 days), or inconsistent CA flags." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "generate" \
        --doc-url "https://lamboot.dev/tools/signing-keys/inspect" \
        --maturity "experimental"

    register_subcommand \
        --name "status" \
        --category "Keys" \
        --summary "Show current Secure Boot state + enrolled certs" \
        --syntax "lamboot-signing-keys status [--json]" \
        --example "lamboot-signing-keys status" \
        --example "sudo lamboot-signing-keys status" \
        --notes "Reads /sys/firmware/efi/efivars/{SecureBoot,SetupMode,AuditMode}-*. Runs mokutil --list-enrolled if available." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "mok-list, mok-enroll" \
        --doc-url "https://lamboot.dev/tools/signing-keys/status" \
        --maturity "experimental"

    register_subcommand \
        --name "mok-enroll" \
        --category "User MOK" \
        --summary "Stage a cert for MOK enrollment (user-mode)" \
        --syntax "lamboot-signing-keys mok-enroll CERT" \
        --arg "CERT:Path to cert to enroll (.der or .crt)" \
        --example "sudo lamboot-signing-keys mok-enroll /etc/keys/db.der" \
        --notes "Wraps mokutil --import. Prompts for one-time enrollment password. Reboot required to complete via MokManager." \
        --offline-capable "false" \
        --requires-root "true" \
        --see-also "mok-list, mok-delete, generate" \
        --doc-url "https://lamboot.dev/tools/signing-keys/mok-enroll" \
        --maturity "experimental"

    register_subcommand \
        --name "mok-list" \
        --category "User MOK" \
        --summary "List MOK-enrolled certs" \
        --syntax "lamboot-signing-keys mok-list [--json]" \
        --example "lamboot-signing-keys mok-list" \
        --notes "Wraps mokutil --list-enrolled." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "mok-enroll" \
        --doc-url "https://lamboot.dev/tools/signing-keys/mok-list" \
        --maturity "experimental"

    register_subcommand \
        --name "mok-delete" \
        --category "User MOK" \
        --summary "Stage MOK deletion (reverses mok-enroll)" \
        --syntax "lamboot-signing-keys mok-delete CERT" \
        --arg "CERT:Path to cert to remove from MOK" \
        --example "sudo lamboot-signing-keys mok-delete /etc/keys/db.der" \
        --notes "Wraps mokutil --delete. Reboot required." \
        --offline-capable "false" \
        --requires-root "true" \
        --see-also "mok-enroll" \
        --doc-url "https://lamboot.dev/tools/signing-keys/mok-delete" \
        --maturity "experimental"

    register_subcommand \
        --name "ovmf-vars" \
        --category "OVMF" \
        --summary "Build OVMF_VARS.fd with cert pre-enrolled in db" \
        --syntax "lamboot-signing-keys ovmf-vars OUTPUT.fd --cert CERT" \
        --arg "OUTPUT.fd:Output OVMF vars file" \
        --arg "--cert PATH:Certificate to embed in db" \
        --example "sudo lamboot-signing-keys ovmf-vars OVMF_VARS_custom.fd --cert /etc/keys/db.crt" \
        --notes "Wraps virt-fw-vars. Consumes stock OVMF_VARS_4M.ms.fd template. Used for Proxmox Config 4 per OVMF-VARS-PROXMOX.md." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "generate, lamboot-pve-ovmf-vars" \
        --doc-url "https://lamboot.dev/tools/signing-keys/ovmf-vars" \
        --maturity "experimental"

    register_subcommand \
        --name "generate-hierarchy" \
        --category "Release Eng" \
        --summary "Generate full PK + KEK + db hierarchy (Scope 1)" \
        --syntax "lamboot-signing-keys generate-hierarchy [--output-dir DIR] [--cn-prefix NAME]" \
        --arg "--output-dir DIR:Output directory (default: ./keys-gen/)" \
        --example "lamboot-signing-keys generate-hierarchy --output-dir ./keys-gen/" \
        --notes "Produces PK (RSA 4096, CA:TRUE, 10y), KEK (RSA 4096, CA:TRUE, 10y), db (RSA 2048, CA:FALSE, codeSigning, 3y) per ~/lamboot-dev/docs/KEY-GENERATION.md §3. Prompts for three passphrases." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "generate, sign-binary" \
        --doc-url "https://lamboot.dev/tools/signing-keys/generate-hierarchy" \
        --maturity "experimental"

    register_subcommand \
        --name "sign-binary" \
        --category "Release Eng" \
        --summary "Sign a binary (Scope 1)" \
        --syntax "lamboot-signing-keys sign-binary BINARY --key KEY --cert CERT [--output OUT] [--sbat CSV|--sbat-file PATH|--no-sbat]" \
        --arg "BINARY:File to sign" \
        --arg "--key PATH:Private key" \
        --arg "--cert PATH:Cert" \
        --arg "--sbat CSV:Inline SBAT CSV line (e.g. \"lamboot,1,LamCo,lamboot,0.8.4,https://lamboot.dev/sbat\")" \
        --arg "--sbat-file PATH:Path to SBAT CSV file (header row + one entry per component); overrides --sbat" \
        --arg "--no-sbat:Skip SBAT section injection (NOT recommended — shim may refuse to chain unsigned SBAT binaries)" \
        --example "lamboot-signing-keys sign-binary dist/lambootx64.efi --key keys/db.key --cert keys/db.crt" \
        --example "lamboot-signing-keys sign-binary dist/lambootx64.efi --key keys/db.key --cert keys/db.crt --sbat-file /etc/lamboot/sbat.csv" \
        --notes "Injects a .sbat PE section before sbsign if not present. Resolution order: --sbat-file > --sbat > /etc/lamboot/sbat.csv > built-in default. Uses objcopy --add-section .sbat=PATH with appropriate flags. SBAT format per https://github.com/rhboot/shim/blob/main/SBAT.md. Pass --no-sbat to skip injection entirely (e.g. when binary already has .sbat)." \
        --offline-capable "false" \
        --requires-root "false" \
        --see-also "generate-hierarchy, lamboot-uki-build" \
        --doc-url "https://lamboot.dev/tools/signing-keys/sign-binary" \
        --maturity "experimental"
