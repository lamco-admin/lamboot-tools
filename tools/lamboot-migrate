        --notes "Invokes lamboot-install. With --preserve-grub (default) the prior bootloader stays as a UEFI fallback. With --remove-grub the tool runs verify first; if all 11 checks pass, it uninstalls the distro's GRUB packages, removes GRUB files from the ESP, and deletes GRUB Boot#### entries from NVRAM. Refuses to remove if verify fails. Requires typed-yes confirmation unless --force." \
        --offline-capable "false" \
        --requires-root "true" \
        --see-also "to-uefi, rollback" \
        --doc-url "https://lamboot.dev/tools/migrate/to-lamboot" \
