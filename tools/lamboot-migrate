#!/bin/bash
# lamboot-migrate — BIOS→UEFI migration and cross-bootloader migration.
#
# The first automated end-to-end BIOS→UEFI migration tool for Linux.
# Handles: MBR→GPT conversion, ESP creation, bootloader installation,
# fstab rewrite, UEFI boot entry creation, verification, and rollback.
#
# Subcommands:
#   to-uefi [OPTIONS]    Convert BIOS/MBR system to UEFI/GPT (10-phase pipeline)
#   to-lamboot [OPTIONS] Migrate UEFI system from competing bootloader to LamBoot
#   verify [OPTIONS]     Run 11-check post-conversion verification
#   rollback [OPTIONS]   Revert the most recent to-uefi run using backup dir
#   status               Show current boot configuration
#
# Governed by ~/lamboot-dev/docs/specs/SPEC-LAMBOOT-MIGRATE.md (SDS-7).
# Part of the lamboot-tools suite; see SPEC-LAMBOOT-TOOLKIT-V1.md §3.1.

# shellcheck source=../lib/lamboot-toolkit-lib.sh
source "${LAMBOOT_LIB_DIR:-/usr/lib/lamboot-tools}/lamboot-toolkit-lib.sh"
# shellcheck source=../lib/lamboot-toolkit-help.sh
source "${LAMBOOT_LIB_DIR:-/usr/lib/lamboot-tools}/lamboot-toolkit-help.sh"

LAMBOOT_TOOL_NAME="lamboot-migrate"
LAMBOOT_TOOL_VERSION="1.0.0"

# ── Tool-specific options ────────────────────────────────────────────────
OPT_SUBCOMMAND=""
OPT_DISK=""
OPT_ESP_SIZE_MB=550
OPT_BOOTLOADER="grub-efi"
OPT_CMDLINE=""
OPT_BACKUP_DIR=""
OPT_METHOD="auto"
OPT_SKIP_VERIFY=0
OPT_KEEP_LEGACY_MBR=1
OPT_PRESERVE_GRUB=1
OPT_REMOVE_GRUB=0
OPT_VERIFY_ALL=0
OPT_VERIFY_PATH=""

# ── Help registry (§10, three-surface rendering) ─────────────────────────
_register_subcommands() {
    register_subcommand \
        --name "to-uefi" \
        --category "Migration" \
        --summary "Convert BIOS/MBR system to UEFI/GPT" \
        --syntax "lamboot-migrate to-uefi [--disk DEV] [--esp-size MB] [--bootloader NAME] [--method A|B|C|auto] [--cmdline STR] [--backup-dir PATH] [--skip-verify] [--keep-legacy-mbr]" \
        --arg "--disk DEV:Target disk (default: auto-detect root disk)" \
        --arg "--esp-size MB:ESP partition size in MB (default: 550)" \
        --arg "--bootloader NAME:grub-efi (default), lamboot, or systemd-boot" \
        --arg "--method A|B|C|auto:Proxmox VM method selector (default: auto)" \
        --arg "--cmdline STR:Override kernel cmdline for new BLS entries" \
        --arg "--backup-dir PATH:Where to store the backup (default: /var/backups/lamboot-migrate-<ts>/)" \
        --arg "--skip-verify:Don't run verification suite after conversion" \
        --arg "--keep-legacy-mbr:Leave MBR boot code (protective) — default" \
        --example "sudo lamboot-migrate to-uefi --disk /dev/sda" \
        --example "sudo lamboot-migrate to-uefi --dry-run" \
        --example "sudo lamboot-migrate to-uefi --bootloader lamboot --esp-size 1024" \
        --notes "Runs a 10-phase pipeline with safety gates at each step. The first 6 phases are reversible with no disk changes (rollback runs a diff). After Phase 4 (MBR→GPT), rollback requires the backup dir. Always back up your system before running. For boot disk migration on physical hardware, run from live media." \
        --offline-capable "false" \
        --requires-root "true" \
        --see-also "to-lamboot, verify, rollback, status" \
        --doc-url "https://lamboot.dev/tools/migrate/to-uefi" \
