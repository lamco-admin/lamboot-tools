        --example "sudo lamboot-migrate rollback --dry-run" \
        --notes "Restores the original MBR partition table, original fstab, and original /etc/default/grub. Removes the UEFI boot entry created during to-uefi. You will need to switch firmware back to Legacy/CSM after rollback to boot off the restored MBR." \
        --offline-capable "false" \
