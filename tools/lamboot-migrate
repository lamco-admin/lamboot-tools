        --offline-capable "false" \
        --requires-root "false" \
        --see-also "to-uefi, rollback" \
        --doc-url "https://lamboot.dev/tools/migrate/verify" \
        --maturity "stable"

    register_subcommand \
        --name "rollback" \
        --category "Recovery" \
        --summary "Revert the most recent to-uefi run using its backup" \
        --syntax "lamboot-migrate rollback [--backup-dir PATH]" \
