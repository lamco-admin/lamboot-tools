    register_subcommand \
        --name "to-lamboot" \
        --category "Migration" \
        --summary "Migrate UEFI system from another bootloader to LamBoot" \
        --syntax "lamboot-migrate to-lamboot [--esp PATH] [--preserve-grub|--remove-grub] [--force]" \
        --arg "--esp PATH:ESP mount point (default: auto-detect)" \
        --arg "--preserve-grub:Keep existing bootloader as fallback (default)" \
        --arg "--remove-grub:Remove GRUB packages + ESP files + NVRAM entries after verify passes (DANGEROUS)" \
        --arg "--force:Skip typed-yes confirmation when --remove-grub is used" \
        --example "sudo lamboot-migrate to-lamboot" \
        --example "sudo lamboot-migrate to-lamboot --preserve-grub" \
        --example "sudo lamboot-migrate to-lamboot --remove-grub    # asks for confirmation" \
