#!/bin/bash
# inline-tool — concatenate shared library into a tool for single-file distribution
#
# Usage: scripts/inline-tool tools/<tool-name> > build/inlined/<tool-name>
#
# Replaces the library source-statement(s) with the library contents, producing
# a self-contained single-file executable suitable for tarball / curl-pipe /
# rescue-media deployment.
#
# Governed by SPEC-LAMBOOT-TOOLKIT-V1.md §6.2.

set -uo pipefail

if [[ $# -ne 1 ]]; then
    printf 'usage: %s <tool-file>\n' "$0" >&2
    exit 1
fi

tool_file="$1"

if [[ ! -f "$tool_file" ]]; then
    printf 'error: tool file not found: %s\n' "$tool_file" >&2
    exit 1
fi

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
lib_main="$repo_root/lib/lamboot-toolkit-lib.sh"
lib_help="$repo_root/lib/lamboot-toolkit-help.sh"

for lib in "$lib_main" "$lib_help"; do
    if [[ ! -f "$lib" ]]; then
        printf 'error: library not found: %s\n' "$lib" >&2
        exit 1
    fi
done

shebang_line=$(head -1 "$tool_file")

printf '%s\n' "$shebang_line"
printf '# INLINED LIBRARY BELOW — DO NOT EDIT\n'
printf '# Edit lib/lamboot-toolkit-lib.sh + lib/lamboot-toolkit-help.sh and rebuild.\n'
printf '# Generated by scripts/inline-tool at %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '\n# ── BEGIN lamboot-toolkit-lib.sh ──────────────────────────────────\n'
tail -n +2 "$lib_main"
printf '\n# ── END lamboot-toolkit-lib.sh ────────────────────────────────────\n'
printf '\n# ── BEGIN lamboot-toolkit-help.sh ─────────────────────────────────\n'
tail -n +2 "$lib_help"
printf '\n# ── END lamboot-toolkit-help.sh ───────────────────────────────────\n'
printf '\n# ── BEGIN tool body ───────────────────────────────────────────────\n'
# Strip the tool's shebang and any `source .../lamboot-toolkit-lib.sh` lines
# (the library is now inlined above).
tail -n +2 "$tool_file" | grep -vE '^[[:space:]]*source[[:space:]]+.*lamboot-toolkit-(lib|help)\.sh' \
                        | grep -vE '^[[:space:]]*#[[:space:]]*shellcheck source=.*lamboot-toolkit-(lib|help)\.sh'
